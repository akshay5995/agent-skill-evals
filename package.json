{
  "name": "agent-skill-evals",
  "version": "0.1.2",
  "private": true,
  "description": "Promptfoo-native toolkit for evaluating reusable agent skills",
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=22.22.0",
    "pnpm": "11.13.1"
  },
  "workspaces": [
    "docs",
    "packages/*",
    "examples"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "pnpm -r --if-present build",
    "schema:generate": "pnpm --dir packages/promptfoo run schema:generate",
    "eval:static": "pnpm --dir packages/promptfoo exec tsx src/cli/init.ts check ../../examples/skills/bugfix-workflow --tests ../../examples/tests/bugfix-workflow.yaml",
    "eval:codex": "pnpm --filter @agent-skill-evals/examples eval:codex",
    "eval:claude": "pnpm --filter @agent-skill-evals/examples eval:claude",
    "eval:pi": "pnpm --filter @agent-skill-evals/examples eval:pi",
    "eval:multiturn": "pnpm --filter @agent-skill-evals/examples eval:multiturn",
    "eval:real": "pnpm --filter @agent-skill-evals/examples eval:real",
    "docs:dev": "pnpm --filter @agent-skill-evals/docs docs:dev",
    "docs:build": "pnpm --filter @agent-skill-evals/docs docs:build",
    "docs:preview": "pnpm --filter @agent-skill-evals/docs docs:preview",
    "release:package-smoke": "node scripts/package-smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "ajv": "^8.20.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.6.2",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.6",
    "vue": "^3.5.13"
  }
}
