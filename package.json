{
  "name": "skillkit",
  "version": "0.1.0",
  "private": true,
  "description": "Promptfoo-native plugin kit for evaluating reusable agent skills",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "examples"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build --workspaces --if-present",
    "eval": "npm run eval --workspace examples",
    "eval:static": "npm run eval:static --workspace examples"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
