{
  "name": "agent-skill-evals",
  "version": "0.1.0",
  "private": true,
  "description": "Promptfoo-native toolkit for evaluating reusable agent skills",
  "type": "module",
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489",
  "engines": {
    "node": "^20.20.0 || >=22.22.0",
    "pnpm": "10.33.3"
  },
  "workspaces": [
    "docs",
    "packages/*",
    "examples"
  ],
  "pnpm": {
    "overrides": {
      "vite@<=6.4.1": "6.4.2",
      "protobufjs@>=8.0.0 <=8.0.1": "8.3.0"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "pnpm -r --if-present build",
    "eval": "pnpm --filter @agent-skill-evals/examples eval",
    "eval:static": "pnpm --filter @agent-skill-evals/examples eval:static",
    "eval:codex": "pnpm --filter @agent-skill-evals/examples eval:codex",
    "eval:claude": "pnpm --filter @agent-skill-evals/examples eval:claude",
    "eval:pi": "pnpm --filter @agent-skill-evals/examples eval:pi",
    "eval:mcp": "pnpm --filter @agent-skill-evals/examples eval:mcp",
    "eval:mcp:claude": "pnpm --filter @agent-skill-evals/examples eval:mcp:claude",
    "eval:mcp:codex": "pnpm --filter @agent-skill-evals/examples eval:mcp:codex",
    "eval:native:pi": "pnpm --filter @agent-skill-evals/examples eval:native:pi",
    "eval:routing": "pnpm --filter @agent-skill-evals/examples eval:routing",
    "eval:real": "pnpm --filter @agent-skill-evals/examples eval:real",
    "docs:dev": "pnpm --filter @agent-skill-evals/docs docs:dev",
    "docs:build": "pnpm --filter @agent-skill-evals/docs docs:build",
    "docs:preview": "pnpm --filter @agent-skill-evals/docs docs:preview",
    "release:package-smoke": "node scripts/package-smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsdown": "^0.21.10",
    "typescript": "^5.6.2",
    "vitepress": "^1.6.3",
    "vitest": "^2.1.2",
    "vue": "^3.5.13"
  }
}
